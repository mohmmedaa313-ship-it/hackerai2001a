{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd /app && pnpm install --filter !@hackerai/desktop && pnpm run build --filter !@hackerai/desktop",
    "watchPatterns": ["app/**", "components/**", "lib/**", "convex/**"]
  },
  "deploy": {
    "startCommand": "cd /app && pnpm run start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
